digraph G {
    rankdir=BT;
    node [shape=box, style=filled, fontname="Helvetica"];
    edge [fontname="Helvetica"];

    // ===== 输入层 =====
    subgraph cluster_input {
        label="Input Layer";
        color="#007bff";
        style=filled;
        fillcolor="#e6f2ff";

        sparse [label="Sparse Features\n(user, feed, author...)", fillcolor="lightgray"];
        dense [label="Dense Feature\n(videoplayseconds)", fillcolor="lightgray"];
        target [label="Target Feed", fillcolor="lightgray"];
        hist [label="History Feed Seq", fillcolor="lightgray"];
    }

    // ===== Embedding =====
    subgraph cluster_emb {
        label="Embedding Layer";
        color="#28a745";
        style=filled;
        fillcolor="#e6ffe6";

        emb [label="Sparse Embedding\n(5 × 16)", fillcolor="lightgoldenrod"];
        feed_emb [label="Feed Embedding\n(512 → 64)", fillcolor="lightpink"];
        hist_emb [label="Hist Embedding\n(Seq × 512 → 64)", fillcolor="lightpink"];
    }

    sparse -> emb;
    target -> feed_emb;
    hist -> hist_emb;

    // ===== Feature Interaction =====
    subgraph cluster_interaction {
        label="Feature Interaction";
        color="#ffc107";
        style=filled;
        fillcolor="#fff3cd";

        fm [label="FM Layer", fillcolor="palegoldenrod"];
        din [label="DIN Attention\n(User Interest)", fillcolor="peachpuff"];
    }

    emb -> fm;
    feed_emb -> din;
    hist_emb -> din;

    // ===== Deep部分 =====
    subgraph cluster_deep {
        label="Deep Network";
        color="#dc3545";
        style=filled;
        fillcolor="#f8d7da";

        dnn_input [label="Concat\n(embed + dense + feed + DIN)", fillcolor="beige"];
        dnn [label="DNN\n(209 → 256 → 128)", fillcolor="salmon"];
        mmoe [label="MMOE\n(4 Tasks, 8 Experts)", fillcolor="darkorange"];
    }

    emb -> dnn_input;
    dense -> dnn_input;
    feed_emb -> dnn_input;
    din -> dnn_input;

    dnn_input -> dnn;
    dnn -> mmoe;

    // ===== Wide部分 =====
    subgraph cluster_wide {
        label="Wide (LR + FM)";
        color="#6c757d";
        style=filled;
        fillcolor="#f1f3f5";

        linear [label="Linear (LR)", fillcolor="lightcoral"];
    }

    sparse -> linear;

    // ===== 输出层 =====
    subgraph cluster_output {
        label="Multi-task Output";
        color="#6f42c1";
        style=filled;
        fillcolor="#e9ecef";

        final [label="Task Heads × 4\n(Concat[LR + FM + MMOE])\nMLP → Logit", fillcolor="mediumpurple"];
    }

    // 连接
    fm -> final;
    linear -> final;
    mmoe -> final;
}
